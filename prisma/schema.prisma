// CECODES Carbon Footprint Tool - domain schema
// See docs/CECODES Carbon Footprint Tool - Requirements.md and docs/CECODES - Tech Stack Decision.md
// All emission/factor numbers use Decimal (Postgres NUMERIC) - never Float/Int - to preserve exact values.
//
// RLS note: tenant tables carry a denormalized `companyId` so Row-Level Security policies can be a
// simple, index-backed `company_id = private.current_company_id()`. The app sets companyId on write.

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Scope {
  SCOPE_1 // Alcance 1 - direct emissions
  SCOPE_2 // Alcance 2 - purchased electricity
  SCOPE_3 // Alcance 3 - other indirect
}

enum GwpSet {
  AR5 // reporting years up to and including 2021 (boundary pending - Req. §12.5)
  AR6 // reporting years after 2021
}

enum Role {
  COMPANY_USER  // Usuario Empresa - sees only their own company
  CECODES_ADMIN // Administrador CECODES - the seeded admin; manages factor library + all companies
}

// What an admin did to a factor. IMPORTED is written by prisma/import-factors.ts; its
// absence on every change row for a factor is what marks that factor "never edited by a
// human", which is the signal the importer uses to decide it may safely overwrite.
enum FactorChangeAction {
  CREATED
  UPDATED
  DEACTIVATED
  REACTIVATED
  IMPORTED
}

// ---------------------------------------------------------------------------
// Identity (Supabase Auth owns auth.users; we mirror role + company link here)
// ---------------------------------------------------------------------------

model AppUser {
  id        String   @id // = Supabase auth user id (uuid)
  email     String   @unique
  role      Role     @default(COMPANY_USER)
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?
  // A deactivated user keeps their auth credentials but is refused at every server entry
  // point (requireAppUser, resolveCompanyScope, resolveAdminScope, signInAction). The role
  // and this flag live in Postgres, not in the JWT, so every request re-reads them and a
  // deactivation takes effect immediately without revoking a session.
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factorChanges EmissionFactorChange[]

  @@index([companyId])
  @@map("app_users")
}

// ---------------------------------------------------------------------------
// Reporting entities: Company -> Facility -> ReportingYear -> ActivityEntry
// ---------------------------------------------------------------------------

model Company {
  id           String     @id @default(uuid())
  name         String // Empresa
  sector       String? // optional; slug from src/lib/sectors.ts, free text for legacy rows
  contactEmail String? // optional; shown on reports
  // A deactivated company blocks its own users. Admins may still open it to fix and
  // reactivate it, which is why resolveCompanyScope checks this only on the company-user path.
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  facilities   Facility[]
  users        AppUser[]

  @@map("companies")
}

model Facility {
  id             String          @id @default(uuid())
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId      String
  name           String // Planta
  location       String // Ubicación / Sede
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reportingYears ReportingYear[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("facilities")
}

model ReportingYear {
  id         String   @id @default(uuid())
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  facilityId String
  companyId  String // denormalized for RLS
  year       Int
  gwpSet     GwpSet // resolved from `year` at creation, but stored for reproducibility
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entries       ActivityEntry[]
  targets       ScopeTarget[]
  results       ResultSnapshot[]
  applicability CategoryApplicability[]

  @@unique([facilityId, year])
  // Backs the composite foreign key from activity_entries, which makes it impossible for a
  // child row to claim one company while its reporting year belongs to another.
  @@unique([id, companyId])
  @@index([companyId])
  @@map("reporting_years")
}

// One activity-data value.
// Scope 2 (electricity) => 12 rows per source (month 1..12).
// Scopes 1 & 3          => 1 row per source (month = null, i.e. annual).
//
// Adding a source creates its rows immediately with value = null, so the rows record that
// the source applies to the year. `value = null` means "not reported yet"; `value = 0`
// means the company genuinely consumed nothing. Both contribute 0 to the total, but only
// the second is an answer.
model ActivityEntry {
  id String @id @default(uuid())

  // Composite foreign key. Binding companyId into the relation makes it impossible for an
  // entry to claim one company while its reporting year belongs to another. It references
  // ReportingYear's @@unique([id, companyId]).
  reportingYear   ReportingYear @relation(fields: [reportingYearId, companyId], references: [id, companyId], onDelete: Cascade)
  reportingYearId String
  companyId       String // denormalized for RLS

  // Link to the factor used, plus denormalized labels/units captured at entry time
  emissionFactor   EmissionFactor? @relation(fields: [emissionFactorId], references: [id])
  emissionFactorId String?

  scope       Scope
  category    String
  subcategory String?
  element     String
  unit        String // consumption unit shown to the user (gal, kWh, kg, km, ...)

  month Int? // 1..12 for Scope 2; null = annual (Scopes 1 & 3)
  value Decimal? @db.Decimal(20, 6) // activity data - decimals allowed, never truncated; null = not reported

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dedupes the 12 Scope-2 month rows. Postgres treats NULLs as distinct, so the annual
  // (month IS NULL) rows are deduped by a partial unique index in the migration instead.
  @@unique([reportingYearId, emissionFactorId, month])
  @@index([reportingYearId, scope])
  @@index([reportingYearId, companyId])
  @@index([companyId])
  @@index([emissionFactorId])
  @@map("activity_entries")
}

// Whether a company declares a whole category applicable for a reporting year. This is
// reportable data, not UI state: the GHG Protocol requires excluded categories to be
// disclosed with a justification, so "no aplica" has to survive to the report.
// Absence of a row means the category applies (the column default). The toggle exists to
// let a company hide sources it does not have, not to opt in.
model CategoryApplicability {
  id              String        @id @default(uuid())
  reportingYear   ReportingYear @relation(fields: [reportingYearId], references: [id], onDelete: Cascade)
  reportingYearId String
  companyId       String // denormalized for RLS
  scope           Scope
  category        String
  applies         Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([reportingYearId, scope, category])
  @@index([companyId])
  @@map("category_applicability")
}

// Reduction target per scope (Meta) - inclusion pending CECODES confirmation (Req. §12.9)
model ScopeTarget {
  id              String        @id @default(uuid())
  reportingYear   ReportingYear @relation(fields: [reportingYearId], references: [id], onDelete: Cascade)
  reportingYearId String
  companyId       String // denormalized for RLS
  scope           Scope
  targetTonnes    Decimal       @db.Decimal(20, 6)
  createdAt       DateTime      @default(now())

  @@unique([reportingYearId, scope])
  @@index([companyId])
  @@map("scope_targets")
}

// ---------------------------------------------------------------------------
// Emission-factor library (admin-maintained, versioned) - Req. §8. Global reference data.
// ---------------------------------------------------------------------------

model EmissionFactorVersion {
  id           String           @id @default(uuid())
  version      String           @unique // e.g. "v005"
  date         DateTime
  preparedBy   String? // Elaboró
  reviewedBy   String? // Revisó
  authorizedBy String? // Autorizó
  description  String? // Descripción de cambios
  createdAt    DateTime         @default(now())
  factors      EmissionFactor[]

  @@map("emission_factor_versions")
}

model EmissionFactor {
  id          String  @id @default(uuid())
  scope       Scope
  category    String
  subcategory String?
  element     String
  unit        String // Unidad Consumo (activity unit)

  // Per-gas factors (modern per-gas model). Any may be null.
  co2Factor Decimal? @db.Decimal(30, 10) // kg CO2 / unit
  ch4Factor Decimal? @db.Decimal(30, 10) // kg CH4 / unit
  n2oFactor Decimal? @db.Decimal(30, 10) // kg N2O / unit

  // Consolidated factor for items already expressed in CO2e (refrigerants, SF6, spend/distance-based)
  co2eFactor    Decimal? @db.Decimal(30, 10) // kg CO2e / unit
  // Alternate consolidated factor per currency for spend-based Scope 3 (purchased goods & services)
  co2eFactorCop Decimal? @db.Decimal(30, 10) // kg CO2e / COP
  co2eFactorUsd Decimal? @db.Decimal(30, 10) // kg CO2e / USD

  factorUnit     String? // Unidad FE
  source         String? // Fuente bibliográfica
  gwpSet         GwpSet? // which GWP vintage the factor assumes, when relevant
  biogenic       Boolean  @default(false) // 0=No biogénica / 1=biogénica
  uncertaintyPct Decimal? @db.Decimal(10, 4)
  effectiveYear  Int? // for year-specific factors
  active         Boolean  @default(true)

  version   EmissionFactorVersion? @relation(fields: [versionId], references: [id])
  versionId String?

  entries   ActivityEntry[]
  changes   EmissionFactorChange[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // The natural key (scope, category, subcategory, element, unit) is enforced by a hand
  // written expression index in the migration, because a plain unique index would treat two
  // NULL subcategories as distinct. It is not declared here: Prisma cannot express COALESCE.

  @@index([scope, category, subcategory])
  @@index([versionId])
  @@index([active])
  @@map("emission_factors")
}

// Per-factor audit trail. Requirements section 8: every change records who, when, and what.
//
// EmissionFactorVersion stays the library RELEASE concept (Excel "Control de Cambios"
// parity: v001..v005). This table is the per-edit record beneath it.
//
// `changes` holds a field diff, { field: { from, to } }, with every Decimal serialized as a
// string. Two full row snapshots per edit would triple the storage and force the UI to diff
// at read time; a CREATED row stores the whole initial state as from:null, so nothing is lost.
model EmissionFactorChange {
  id             String             @id @default(uuid())
  factor         EmissionFactor     @relation(fields: [factorId], references: [id], onDelete: Cascade)
  factorId       String
  changedBy      AppUser?           @relation(fields: [changedById], references: [id], onDelete: SetNull)
  changedById    String?
  changedByEmail String // denormalized: the audit row must outlive the actor
  action         FactorChangeAction
  changes        Json
  changedAt      DateTime           @default(now())

  @@index([factorId, changedAt])
  @@map("emission_factor_changes")
}

// Scope-2 national grid factor by year (SIN) - Req. §7.3. Global reference data.
model GridElectricityFactor {
  id             String   @id @default(uuid())
  year           Int      @unique
  factor         Decimal  @db.Decimal(30, 10) // kg CO2 / kWh
  source         String? // UPME / XM
  createdAt      DateTime @default(now())
  // Who last touched this year, and when. A full change table is unnecessary here: the year
  // rows are themselves the history, and the library version notes record the release.
  updatedAt      DateTime @default(now()) @updatedAt
  updatedByEmail String?

  @@map("grid_electricity_factors")
}

// ---------------------------------------------------------------------------
// Computed results (pinned to the factor version used, for reproducibility) - Req. §8, §14
// ---------------------------------------------------------------------------

model ResultSnapshot {
  id              String        @id @default(uuid())
  reportingYear   ReportingYear @relation(fields: [reportingYearId], references: [id], onDelete: Cascade)
  reportingYearId String
  companyId       String // denormalized for RLS
  scope           Scope
  category        String?
  tonnesCo2e      Decimal       @db.Decimal(20, 6)
  biogenicTonnes  Decimal?      @db.Decimal(20, 6) // biogenic CO2 memo item (kept out of headline) - Req. §12.5
  factorVersionId String? // which factor library version produced this
  computedAt      DateTime      @default(now())

  @@index([reportingYearId])
  @@index([companyId])
  @@map("result_snapshots")
}
